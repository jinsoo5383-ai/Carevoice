     if (isHidden) highlightMapSido(document.getElementById('filter-region').value);
   }
 
+  let sigunguMapData = null; // 시군구 경계 지도 데이터 (지연 로드)
+
+  async function loadSigunguMapData() {
+    if (sigunguMapData) return sigunguMapData;
+    try {
+      const res = await fetch('/sigungu-map.json');
+      sigunguMapData = await res.json();
+    } catch (err) {
+      sigunguMapData = {};
+    }
+    return sigunguMapData;
+  }
+
   // 지도에서 시도를 클릭했을 때
-  function selectSidoFromMap(code) {
+  async function selectSidoFromMap(code) {
     document.getElementById('filter-region').value = code;
     highlightMapSido(code);
     onRegionChange();
+    await zoomToSido(code);
   }
 
+  // 시도 확대 지도를 그림 (시군구 클릭용)
+  async function zoomToSido(code) {
+    const mapData = await loadSigunguMapData();
+    const sidoInfo = mapData[code];
+    if (!sidoInfo || !sidoInfo.paths || sidoInfo.paths.length === 0) return; // 세종처럼 시군구가 없으면 확대하지 않음
+
+    document.getElementById('national-map-view').style.display = 'none';
+    document.getElementById('sido-zoom-view').style.display = '';
+    document.getElementById('zoom-sido-label').textContent = SIDO_NAME_MAP[code] || '';
+
+    const svg = document.getElementById('sido-zoom-svg');
+    svg.setAttribute('viewBox', sidoInfo.viewBox);
+    svg.innerHTML = sidoInfo.paths.map(p =>
+      `<path class="sido-path" data-sigungu="${p.code}" d="${p.d}" onclick="selectSigunguFromMap('${code}','${p.code}')"><title>${p.name}</title></path>`
+    ).join('');
+  }
+
+  function showNationalMap() {
+    document.getElementById('sido-zoom-view').style.display = 'none';
+    document.getElementById('national-map-view').style.display = '';
+  }
+
+  // 확대 지도에서 시군구를 클릭했을 때
+  function selectSigunguFromMap(sidoCode, sigunguCode) {
+    document.getElementById('filter-sigungu').value = sigunguCode;
+    document.querySelectorAll('#sido-zoom-svg .sido-path').forEach(el => {
+      el.classList.toggle('active', el.getAttribute('data-sigungu') === sigunguCode);
+    });
+    searchFacilities();
+  }
+
+  const SIDO_NAME_MAP = {
+    '11':'서울','26':'부산','27':'대구','28':'인천','29':'광주','30':'대전','31':'울산','36':'세종',
+    '41':'경기','43':'충북','44':'충남','46':'전남','47':'경북','48':'경남','50':'제주','51':'강원','52':'전북'
+  };
+
   // 현재 선택된 시도를 지도에서 하이라이트
   function highlightMapSido(code) {
     document.querySelectorAll('.sido-path').forEach(el => {
@@ -1896,6 +1957,7 @@

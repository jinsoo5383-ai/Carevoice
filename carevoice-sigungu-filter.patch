       if (facilityKeyword) params.append('keyword', facilityKeyword);
       if (facilityRegion) params.append('region', facilityRegion);
+      if (facilityRegion && facilitySigungu) params.append('sigungu', facilitySigungu);
       params.append('page', facilityPage);
 
       const res = await fetch(`/api/facilities/search?${params}`);
@@ -2029,7 +2070,7 @@
       loadFacilityDetailPage(detailId, params.get('type'), decodeURIComponent(params.get('name') || ''), params.get('region'));
     } else {
       document.getElementById('filter-region').value = '11';
-      searchFacilities();
+      onRegionChange();
     }
   })();

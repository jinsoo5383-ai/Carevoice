   let facilityPage = 1;
   let facilityKeyword = '';
   let facilityRegion = '';
+  let facilitySigungu = '';
+  let sigunguCache = {}; // sido code -> [{code, name}]
   let facilityDataMap = {}; // longTermAdminSym -> item
 
+  // 시도가 바뀌면 시군구 목록을 다시 불러와 드롭다운을 채움
+  async function onRegionChange() {
+    const region = document.getElementById('filter-region').value;
+    const sigunguSelect = document.getElementById('filter-sigungu');
+
+    if (!region) {
+      sigunguSelect.style.display = 'none';
+      sigunguSelect.innerHTML = '<option value="">전체</option>';
+      searchFacilities();
+      return;
+    }
+
+    try {
+      if (!sigunguCache[region]) {
+        const res = await fetch(`/api/regions/sigungu?sido=${region}`);
+        const data = await res.json();
+        sigunguCache[region] = data.items || [];
+      }
+      const items = sigunguCache[region];
+      if (items.length > 0) {
+        sigunguSelect.innerHTML = '<option value="">전체</option>' +
+          items.map(it => `<option value="${it.code}">${it.name}</option>`).join('');
+        sigunguSelect.style.display = '';
+      } else {
+        sigunguSelect.style.display = 'none';
+        sigunguSelect.innerHTML = '<option value="">전체</option>';
+      }
+    } catch (err) {
+      sigunguSelect.style.display = 'none';
+    }
+
+    searchFacilities();
+  }
+
   function renderFacilityCards(items, append) {

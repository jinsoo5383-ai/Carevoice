- 검색결과 영역을 content-flex 컨테이너로 감싸 지도 패널과 나란히 배치
- 지도 열림/닫힘에 따라 map-open 클래스 토글, 전체 폭 640px <-> 1180px 전환
- 900px 이하 화면에서는 기존처럼 세로로 쌓이도록 반응형 처리
---
 public/index.html | 48 ++++++++++++++++++++++++++++++++++++++++++++---
 1 file changed, 45 insertions(+), 3 deletions(-)

diff --git a/public/index.html b/public/index.html
index 585fa6a..784d15e 100644
--- a/public/index.html
+++ b/public/index.html
@@ -234,6 +234,43 @@
       padding: 20px 16px;
     }
 
+    .content-flex {
+      display: flex;
+      align-items: flex-start;
+      justify-content: center;
+      gap: 20px;
+      max-width: 640px;
+      margin: 0 auto;
+      transition: max-width 0.15s;
+    }
+    .content-flex.map-open {
+      max-width: 1180px;
+    }
+    #region-map-wrap {
+      flex: 0 0 auto;
+      width: 380px;
+      margin-top: 12px;
+      position: sticky;
+      top: 12px;
+    }
+    #region-map-wrap .sigungu-label {
+      font-size: 7px;
+    }
+    #results-main {
+      flex: 1 1 auto;
+      min-width: 0;
+    }
+    @media (max-width: 900px) {
+      .content-flex {
+        flex-direction: column;
+        align-items: stretch;
+      }
+      #region-map-wrap {
+        width: auto;
+        position: static;
+      }
+    }
+
     .section-header {
       display: flex;
       justify-content: space-between;
@@ -1078,7 +1115,10 @@
       <option value="score">평가점수 높은순</option>
     </select>
   </div>
-  <div id="region-map-wrap" style="display:none; margin-top:12px;"><div style="max-width:520px; margin:0 auto; background:var(--white); border:1px solid var(--border); border-radius:12px; padding:12px;">
+</div>
